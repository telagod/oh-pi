{
  "name": "oh-pi",
  "version": "0.1.85",
  "description": "Ant Colony for Pi — bootstrap and package distribution for a multi-agent Pi plugin for complex coding tasks.",
  "type": "module",
  "bin": {
    "oh-pi": "dist/bin/oh-pi.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "pi-package",
    "README.md",
    "!**/*.test.ts",
    "!**/*.spec.ts"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/oh-pi.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "ant-colony",
    "multi-agent",
    "plugin",
    "setup",
    "tui"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./pi-package/extensions"
    ],
    "skills": [
      "./pi-package/skills"
    ],
    "prompts": [
      "./pi-package/prompts"
    ],
    "themes": [
      "./pi-package/themes"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
